!macro NSIS_HOOK_POSTINSTALL
  DetailPrint "Checking Ollama dependency"
  IfFileExists "$LOCALAPPDATA\Programs\Ollama\ollama.exe" ollama_done 0

  DetailPrint "Installing Ollama for local email drafts"
  ; Encoded PowerShell downloads the official OllamaSetup.exe, tries /S,
  ; falls back to interactive setup, then starts Ollama when present.
  nsExec::ExecToLog 'powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand '
  Pop $0
  StrCmp $0 "0" ollama_done 0

  DetailPrint "Ollama automatic install failed: $0"
  MessageBox MB_ICONEXCLAMATION|MB_OK "Veyra was installed, but Ollama could not be installed automatically. Open Veyra Settings > Transcription and click Install Ollama."

ollama_done:
!macroend

