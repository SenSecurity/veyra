{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Veyra",
  "version": "0.1.20",
  "identifier": "com.typr.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Veyra",
        "width": 900,
        "height": 600,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "theme": "Light",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/whisper-cpp"],
    "resources": [
      "binaries/whisper.dll",
      "binaries/ggml.dll",
      "binaries/ggml-base.dll",
      "binaries/ggml-cpu.dll",
      "binaries/ggml-blas.dll",
      "binaries/libopenblas.dll"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
